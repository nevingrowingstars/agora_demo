    "version": "0.2.0",
    "configurations": [

        
        {
            "name": "agora_demo (Web)-Security Disabled",
            "request": "launch",
            "type": "dart",
            "flutterMode": "debug",
            "deviceId": "chrome",
            "program": "lib/main.dart",
            "toolArgs": [
                "-d",
                "chrome"
            ],
            "args": [
                "--web-port=50323",
                "--web-browser-flag=--disable-web-security"
            ]
        },
    ]
}